# Bounty Factory Environment Variables
# Copy this to .env and fill in your actual values

# Algora.io API Key (get from https://algora.io/settings/api)
ALGORA_API_KEY=your_algora_api_key_here

# OpenCode API Key (get from https://opencode.ai/settings)
OPENCODE_API_KEY=your_opencode_api_key_here

# GitHub Personal Access Token (with repo and push permissions)
GITHUB_TOKEN=your_github_token_here

# GitHub Username
GITHUB_USERNAME=your_github_username

# Optional: Override config path
# BOUNTY_FACTORY_CONFIG=/path/to/config.yaml